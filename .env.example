# Application
APP_NAME=infra-test-api
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000

# Database (used by app and Alembic)
# When running the API on the host (uvicorn), use localhost and the host port below
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=infra_test_db

# Docker only: host port for postgres (default 5433 to avoid conflict with local Postgres on 5432)
# POSTGRES_HOST_PORT=5433

# When using full Docker Compose, the api service uses POSTGRES_HOST=postgres and port 5432 (internal)

DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
